# Supabase — copy this file to `.env.local` and fill in the values from your
# Supabase project (Project Settings → API). Do NOT commit `.env.local`.

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose; access is enforced by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SECRET. Bypasses Row Level Security. Server-side only.
# Never expose this to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
